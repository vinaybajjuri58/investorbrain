<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
  xml:base="http://investorbrain.ai/ontology/investing">

  <owl:Ontology rdf:about="http://investorbrain.ai/ontology/investing">
    <rdfs:label>InvestorBrain Investing Ontology</rdfs:label>
    <rdfs:comment>Domain ontology for structuring investing content: sources, creators, companies, theses, catalysts, biases, and personal notes.</rdfs:comment>
  </owl:Ontology>

  <!-- ═══════════════════════════════════════════════════════════
       Classes
       ═══════════════════════════════════════════════════════════ -->

  <owl:Class rdf:about="http://investorbrain.ai/ontology/investing#Source">
    <rdfs:label>Source</rdfs:label>
    <rdfs:comment>A piece of investing content — a YouTube video, blog post, research note, or any ingested document.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://investorbrain.ai/ontology/investing#Creator">
    <rdfs:label>Creator</rdfs:label>
    <rdfs:comment>The author, analyst, or channel that produced a Source.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://investorbrain.ai/ontology/investing#Company">
    <rdfs:label>Company</rdfs:label>
    <rdfs:comment>A publicly or privately traded company mentioned or analysed in investing content.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://investorbrain.ai/ontology/investing#SectorTheme">
    <rdfs:label>SectorTheme</rdfs:label>
    <rdfs:comment>A market sector or macro investment theme (e.g., Semiconductors, Clean Energy, AI Infrastructure).</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://investorbrain.ai/ontology/investing#Thesis">
    <rdfs:label>Thesis</rdfs:label>
    <rdfs:comment>An investment thesis: a structured claim that a company, sector, or macro trend will outperform or underperform over a stated horizon. Carries a bullish/bearish/neutral stance and the reasoning behind it. Theses can contradict or reinforce each other and hinge on specific catalysts.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://investorbrain.ai/ontology/investing#Catalyst">
    <rdfs:label>Catalyst</rdfs:label>
    <rdfs:comment>A specific, dateable event or condition that could trigger or validate a thesis — such as an earnings release, regulatory decision, product launch, or macro data print. Affects one or more companies. Has an expected or actual eventDate.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://investorbrain.ai/ontology/investing#Bias">
    <rdfs:label>Bias</rdfs:label>
    <rdfs:comment>A documented cognitive, positional, or structural bias a Creator may hold — for example, confirmation bias, long-only mandate, sell-side coverage obligations, or undisclosed ownership. Knowing a Creator's biases helps calibrate how much weight to give their theses.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://investorbrain.ai/ontology/investing#Note">
    <rdfs:label>Note</rdfs:label>
    <rdfs:comment>A personal annotation or raw note added by the user, not sourced from an external URL.</rdfs:comment>
  </owl:Class>

  <!-- ═══════════════════════════════════════════════════════════
       Object Properties
       ═══════════════════════════════════════════════════════════ -->

  <owl:ObjectProperty rdf:about="http://investorbrain.ai/ontology/investing#AUTHORED_BY">
    <rdfs:label>AUTHORED_BY</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Source"/>
    <rdfs:range rdf:resource="http://investorbrain.ai/ontology/investing#Creator"/>
    <rdfs:comment>Links a Source to the Creator who produced it.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://investorbrain.ai/ontology/investing#MENTIONS">
    <rdfs:label>MENTIONS</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Source"/>
    <rdfs:range rdf:resource="http://investorbrain.ai/ontology/investing#Company"/>
    <rdfs:comment>A Source mentions (discusses or references) a Company.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://investorbrain.ai/ontology/investing#ARGUES">
    <rdfs:label>ARGUES</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Source"/>
    <rdfs:range rdf:resource="http://investorbrain.ai/ontology/investing#Thesis"/>
    <rdfs:comment>A Source advances or presents a particular investment Thesis.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://investorbrain.ai/ontology/investing#ABOUT">
    <rdfs:label>ABOUT</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Thesis"/>
    <rdfs:range rdf:resource="http://investorbrain.ai/ontology/investing#Company"/>
    <rdfs:comment>The primary Company a Thesis is making a claim about.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://investorbrain.ai/ontology/investing#HINGES_ON">
    <rdfs:label>HINGES_ON</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Thesis"/>
    <rdfs:range rdf:resource="http://investorbrain.ai/ontology/investing#Catalyst"/>
    <rdfs:comment>A Thesis depends on a specific Catalyst materialising for its validity.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://investorbrain.ai/ontology/investing#CONTRADICTS">
    <rdfs:label>CONTRADICTS</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Thesis"/>
    <rdfs:range rdf:resource="http://investorbrain.ai/ontology/investing#Thesis"/>
    <rdfs:comment>One Thesis directly contradicts another (e.g., bull vs. bear thesis on the same company).</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://investorbrain.ai/ontology/investing#SUPPORTS">
    <rdfs:label>SUPPORTS</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Thesis"/>
    <rdfs:range rdf:resource="http://investorbrain.ai/ontology/investing#Thesis"/>
    <rdfs:comment>One Thesis provides corroborating evidence or reasoning for another.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://investorbrain.ai/ontology/investing#AFFECTS">
    <rdfs:label>AFFECTS</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Catalyst"/>
    <rdfs:range rdf:resource="http://investorbrain.ai/ontology/investing#Company"/>
    <rdfs:comment>A Catalyst event directly impacts a Company's valuation or prospects.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://investorbrain.ai/ontology/investing#IN_SECTOR">
    <rdfs:label>IN_SECTOR</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Company"/>
    <rdfs:range rdf:resource="http://investorbrain.ai/ontology/investing#SectorTheme"/>
    <rdfs:comment>A Company belongs to or is primarily associated with a SectorTheme.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://investorbrain.ai/ontology/investing#HAS_BIAS">
    <rdfs:label>HAS_BIAS</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Creator"/>
    <rdfs:range rdf:resource="http://investorbrain.ai/ontology/investing#Bias"/>
    <rdfs:comment>Associates a documented Bias with a Creator.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://investorbrain.ai/ontology/investing#COVERS">
    <rdfs:label>COVERS</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Creator"/>
    <rdfs:range rdf:resource="http://investorbrain.ai/ontology/investing#SectorTheme"/>
    <rdfs:comment>A Creator regularly produces content about a particular SectorTheme.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://investorbrain.ai/ontology/investing#ANNOTATES">
    <rdfs:label>ANNOTATES</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Note"/>
    <rdfs:range>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="http://investorbrain.ai/ontology/investing#Thesis"/>
          <owl:Class rdf:about="http://investorbrain.ai/ontology/investing#Company"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:range>
    <rdfs:comment>A personal Note annotates (comments on) either a Thesis or a Company.</rdfs:comment>
  </owl:ObjectProperty>

  <!-- ═══════════════════════════════════════════════════════════
       Data Properties
       ═══════════════════════════════════════════════════════════ -->

  <owl:DatatypeProperty rdf:about="http://investorbrain.ai/ontology/investing#stance">
    <rdfs:label>stance</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Thesis"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>The directional stance of a Thesis: "bullish", "bearish", or "neutral".</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://investorbrain.ai/ontology/investing#reasoning">
    <rdfs:label>reasoning</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Thesis"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>A free-text summary of the key arguments and evidence supporting the Thesis.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://investorbrain.ai/ontology/investing#eventDate">
    <rdfs:label>eventDate</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Catalyst"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:comment>The expected or actual calendar date on which a Catalyst event occurs or is resolved.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://investorbrain.ai/ontology/investing#biasType">
    <rdfs:label>biasType</rdfs:label>
    <rdfs:domain rdf:resource="http://investorbrain.ai/ontology/investing#Bias"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment>A short label for the type of bias, e.g. "confirmation bias", "long-only mandate", "sell-side coverage", "undisclosed ownership".</rdfs:comment>
  </owl:DatatypeProperty>

</rdf:RDF>
