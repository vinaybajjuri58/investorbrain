# =============================================================================
# InvestorBrain — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI — LLM (required)
# Used by Cognee for knowledge extraction and reasoning.
# -----------------------------------------------------------------------------
LLM_API_KEY="sk-..."
LLM_PROVIDER="openai"
LLM_MODEL="openai/gpt-4o-mini"

# -----------------------------------------------------------------------------
# OpenAI — Embeddings (required)
# If EMBEDDING_API_KEY is not set, LLM_API_KEY is used automatically.
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER="openai"
EMBEDDING_MODEL="openai/text-embedding-3-large"
EMBEDDING_DIMENSIONS=3072
# EMBEDDING_API_KEY="sk-..."   # Uncomment only if using a separate key

# -----------------------------------------------------------------------------
# Relational DB — SQLite (file-based, no setup needed)
# -----------------------------------------------------------------------------
DB_PROVIDER="sqlite"
DB_NAME="cognee_db"

# -----------------------------------------------------------------------------
# Graph DB — KuzuDB (file-based, no setup needed)
# -----------------------------------------------------------------------------
GRAPH_DATABASE_PROVIDER="kuzu"
GRAPH_DATASET_DATABASE_HANDLER="kuzu"

# -----------------------------------------------------------------------------
# Vector DB — LanceDB (file-based, no setup needed)
# -----------------------------------------------------------------------------
VECTOR_DB_PROVIDER="lancedb"
VECTOR_DATASET_DATABASE_HANDLER="lancedb"

# -----------------------------------------------------------------------------
# Cognee data storage paths (inside the Docker container)
# These match the bind mounts defined in docker-compose.yml.
# -----------------------------------------------------------------------------
DATA_ROOT_DIRECTORY="/app/.cognee_data"
SYSTEM_ROOT_DIRECTORY="/app/.cognee_system"

# -----------------------------------------------------------------------------
# Cognee API server settings
# -----------------------------------------------------------------------------
FASTAPI_USERS_JWT_SECRET="change-me-to-a-long-random-secret"
REQUIRE_AUTHENTICATION=False
ENABLE_BACKEND_ACCESS_CONTROL=False

# -----------------------------------------------------------------------------
# Web app — URL of the self-hosted Cognee service
# Used by the Next.js app to call the Cognee REST API.
# -----------------------------------------------------------------------------
COGNEE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
ENV="local"
LITELLM_LOG="ERROR"
TOKENIZERS_PARALLELISM="false"
